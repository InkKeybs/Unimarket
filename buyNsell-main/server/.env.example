# Example .env for the server
# Copy this to .env and fill in real values (do NOT commit .env with secrets)

# MongoDB connection string (Atlas). Example:
# ATLAS_KEY=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
ATLAS_KEY=

# JWT secrets
JWTPRIVATEKEY=
JWTREFRESHPRIVATEKEY=

# Email (nodemailer) settings
SERVICE=Gmail
USER=
PASS=

# Frontend origin(s) allowed by CORS (comma-separated)
# Example: https://unimarket.vercel.app
CORS_ORIGIN=

# Base URL used in emails
# Example: https://unimarket.vercel.app/
BASE_URL=

# Server port (optional, defaults to 5000)
PORT=5000
